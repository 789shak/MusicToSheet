{
  "expo": {
    "name": "Music-To-Sheet",
    "slug": "music-to-sheet",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "musictosheet",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.musictosheet.app",
      "buildNumber": "1",
      "supportsTablet": true
    },
    "android": {
      "package": "com.musictosheet.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#111118"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#111118"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
